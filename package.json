{
  "name": "prateekchhikara.github.io",
  "version": "1.0.0",
  "description": "Personal website for Prateek Chhikara.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prateekchhikara/prateekchhikara.github.io.git"
  },
  "keywords": [
    "jekyll",
    "github-pages",
    "personal-website"
  ],
  "author": "Prateek Chhikara",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/prateekchhikara/prateekchhikara.github.io/issues"
  },
  "homepage": "https://www.prateekchhikara.com",
  "engines": {
    "node": ">= 18"
  },
  "devDependencies": {
    "npm-run-all": "^1.7.0",
    "onchange": "^2.2.0",
    "uglify-js": "^2.6.1"
  },
  "scripts": {
    "serve": "bundle exec jekyll serve --config _config.yml,_config.dev.yml",
    "build": "bundle exec jekyll build",
    "uglify": "uglifyjs assets/js/vendor/jquery/jquery-1.12.4.min.js assets/js/plugins/jquery.fitvids.js assets/js/plugins/jquery.greedy-navigation.js assets/js/plugins/jquery.magnific-popup.js assets/js/plugins/jquery.smooth-scroll.min.js assets/js/plugins/stickyfill.min.js assets/js/_main.js -c -m -o assets/js/main.min.js",
    "watch:js": "onchange \"assets/js/**/*.js\" -e \"assets/js/main.min.js\" -- npm run build:js",
    "build:js": "npm run uglify"
  }
}
